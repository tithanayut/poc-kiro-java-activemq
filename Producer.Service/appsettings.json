{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      }
    }
  },
  "Producer": {
    "BrokerUrl": "activemq:tcp://localhost:61616",
    "TopicName": "product.orders",
    "Retry": {
      "InitialDelayMs": 1000,
      "MaxDelayMs": 60000,
      "BackoffMultiplier": 2.0
    }
  }
}
